# =============================================================================
# suricata_dos_rules.rules
# ============================================================
# SURICATA RULES - Layer 7 DoS Detection
# Mục đích: Demo / Benchmark / PoC quy mô nhỏ
# Môi trường: HTTP port 80, HTTPS port 443
# Lưu ý: Chỉnh threshold cho phù hợp môi trường thực tế
# Yêu cầu: Suricata >= 6.0
# Lưu ý comment: File này CHỈ dùng để đọc/tham khảo.
#                Khi nạp vào Suricata phải dùng file _no_comments.rules
#                vì Suricata không chấp nhận comment trong rule file.
# ============================================================


# ============================================================
# SLOWLORIS
# Cơ chế: Mở hàng nghìn TCP connection, gửi header HTTP rất chậm (từng dòng một) để giữ thread server mãi mãi.
# ============================================================

# Rule 1: Nhiều SYN mới từ cùng một IP — dấu hiệu đặc trưng nhất của Slowloris
# Slowloris liên tục mở connection mới khi connection cũ bị timeout.
# 20 connection trong 10 giây là ngưỡng đủ nhạy mà ít false positive.
alert tcp any any -> $HOME_NET 80 (msg:"SLOWLORIS Excessive new TCP connections from single IP"; flags:S; flow:to_server; threshold: type threshold, track by_src, count 20, seconds 10; sid:9000001; rev:2; classtype:attempted-dos; metadata:affected_product Web_Server, attack_target HTTP;)

# Rule 2: HTTP request payload cực nhỏ — Slowloris gửi từng dòng header một,
# mỗi packet chỉ vài byte. dsize < 50 bắt các packet "nhỏ giọt" bất thường.
# FIX v2: Dùng http.method sticky buffer thay vì content:"GET" trên raw TCP
#         để tránh false positive khi "GET" xuất hiện trong payload không liên quan.
alert http any any -> $HOME_NET 80 (msg:"SLOWLORIS Tiny HTTP payload - possible partial header drip"; flow:established,to_server; http.method; content:"GET"; dsize:<50; threshold: type threshold, track by_src, count 10, seconds 30; sid:9000002; rev:2; classtype:attempted-dos; metadata:affected_product Web_Server, attack_target HTTP;)

# Rule 3: Header "X-a:" là dấu vết đặc trưng của tool Slowloris gốc (perl script).
# Tool mặc định gửi header giả "X-a: b" để duy trì connection.
alert tcp any any -> $HOME_NET 80 (msg:"SLOWLORIS Tool signature header X-a detected"; flow:established,to_server; content:"X-a:"; threshold: type threshold, track by_src, count 5, seconds 10; sid:9000003; rev:2; classtype:attempted-dos; metadata:affected_product Web_Server, attack_target HTTP;)

# Rule 4: Safety net — nhiều SYN liên tục trong 60 giây, ngưỡng cao hơn.
# Bắt các biến thể Slowloris dùng connection pool lớn (--socket-count 500+).
alert tcp any any -> $HOME_NET 80 (msg:"SLOWLORIS Sustained connection flood over 60s"; flags:S; flow:to_server; threshold: type threshold, track by_src, count 50, seconds 60; sid:9000004; rev:2; classtype:attempted-dos; metadata:affected_product Web_Server, attack_target HTTP;)


# ============================================================
# RUDY (R-U-Dead-Yet) — Slow POST Attack
# Cơ chế: Gửi POST với Content-Length rất lớn, nhưng body
# chỉ trickle từng byte một. Server giữ thread chờ body mãi.
# ============================================================

# Rule 5: POST request với Content-Length bất thường lớn (>= 10MB).
# Người dùng thực sự hiếm khi POST file >10MB qua form thường.
# Ngưỡng 3 request như vậy trong 10 giây là dấu hiệu rõ của RUDY.
# FIX v2: Thêm http.header; trước pcre để gắn đúng buffer — nếu thiếu,
#         Suricata sẽ apply pcre trên raw packet thay vì HTTP header,
#         dẫn đến false negative hoặc crash rule load.
alert http any any -> $HOME_NET 80 (msg:"RUDY Large Content-Length POST request detected"; flow:established,to_server; http.method; content:"POST"; http.header; content:"Content-Length:"; http.header; pcre:"/Content-Length:\s*[1-9][0-9]{7,}/i"; threshold: type threshold, track by_src, count 3, seconds 10; sid:9001001; rev:2; classtype:attempted-dos; metadata:affected_product Web_Server, attack_target HTTP_POST;)

# Rule 6: POST payload cực nhỏ (< 30 byte) — body "nhỏ giọt" đặc trưng của RUDY.
# Kết hợp với rule 5 để tăng độ chính xác.
# FIX v2: Dùng http.method sticky buffer thay vì content:"POST" trên raw TCP.
alert http any any -> $HOME_NET 80 (msg:"RUDY Tiny POST body fragment - slow body drip pattern"; flow:established,to_server; http.method; content:"POST"; dsize:<30; threshold: type threshold, track by_src, count 15, seconds 30; sid:9001002; rev:2; classtype:attempted-dos; metadata:affected_product Web_Server, attack_target HTTP_POST;)

# Rule 7: RUDY nhắm vào endpoint form submission — /login, /upload, /comment...
# Rule này bắt POST tới các endpoint phổ biến với tần suất cao bất thường.
# FIX v2: Thêm http.uri; trước pcre để gắn đúng buffer URI.
alert http any any -> $HOME_NET 80 (msg:"RUDY Repeated POST to form endpoint"; flow:established,to_server; http.method; content:"POST"; http.uri; pcre:"/(login|upload|submit|register|comment|contact)/i"; threshold: type threshold, track by_src, count 10, seconds 20; sid:9001003; rev:2; classtype:attempted-dos; metadata:affected_product Web_Server, attack_target Form_Endpoint;)


# ============================================================
# HTTP GET FLOOD
# Cơ chế: Gửi hàng triệu HTTP GET hợp lệ để làm cạn tài
# nguyên CPU/RAM server. Request trông bình thường, chỉ khác
# ở volume cực lớn từ một nguồn.
# ============================================================

# Rule 8: Volume GET cao từ một IP — ngưỡng 100 request/10s.
# User bình thường hiếm khi vượt quá 20-30 request trong 10 giây.
alert http any any -> $HOME_NET 80 (msg:"HTTP GET FLOOD High volume GET requests from single source"; flow:established,to_server; http.method; content:"GET"; threshold: type threshold, track by_src, count 100, seconds 10; sid:9002001; rev:2; classtype:attempted-dos; metadata:affected_product Web_Server, attack_target HTTP;)

# Rule 9: GET Flood nhắm vào một URL cụ thể (index, homepage).
# Attacker thường tập trung vào trang nặng nhất để tối đa hoá thiệt hại.
# FIX v2: Thêm http.uri; trước content:"/" để gắn đúng buffer URI.
alert http any any -> $HOME_NET 80 (msg:"HTTP GET FLOOD Concentrated requests to single URI"; flow:established,to_server; http.method; content:"GET"; http.uri; content:"/"; threshold: type both, track by_src, count 200, seconds 30; sid:9002002; rev:2; classtype:attempted-dos; metadata:affected_product Web_Server, attack_target HTTP_Root;)

# Rule 10: GET không có User-Agent — tool đơn giản thường bỏ qua header này.
# Hầu hết browser thực đều gửi User-Agent, nên thiếu header này là dấu hiệu đáng ngờ.
# FIX v2: Đổi http.header_names (chỉ có Suricata >= 6.0, dễ gây lỗi load)
#         sang http.header với negation content:!"User-Agent:" — tương thích rộng hơn.
#         Cú pháp negation đúng: ! đứng TRƯỚC dấu ngoặc kép, không phải trong keyword.
alert http any any -> $HOME_NET 80 (msg:"HTTP GET FLOOD Missing User-Agent - likely automated tool"; flow:established,to_server; http.method; content:"GET"; http.header; content:!"User-Agent:"; threshold: type threshold, track by_src, count 20, seconds 10; sid:9002003; rev:2; classtype:attempted-dos; metadata:affected_product Web_Server, attack_target HTTP;)


# ============================================================
# HTTPS FLOOD / SSL EXHAUSTION
# Cơ chế: Tạo hàng nghìn TLS handshake mới liên tục. Server
# tốn CPU gấp 10-15x client cho mỗi handshake (asymmetry).
# ============================================================

# Rule 11: Nhiều SYN tới port 443 — khởi đầu của mọi TLS handshake mới.
# 30 connection trong 10 giây là ngưỡng phù hợp cho demo.
alert tcp any any -> $HOME_NET 443 (msg:"HTTPS FLOOD Excessive new TLS connections from single IP"; flags:S; flow:to_server; threshold: type threshold, track by_src, count 30, seconds 10; sid:9003001; rev:2; classtype:attempted-dos; metadata:affected_product Web_Server, attack_target HTTPS;)

# Rule 12: TLS ClientHello liên tục — byte đầu của TLS record là 0x16 (ContentType=Handshake)
# tiếp theo là 0x03 (version byte). Đây là dấu vết rõ nhất của SSL exhaustion.
alert tcp any any -> $HOME_NET 443 (msg:"HTTPS FLOOD Repeated TLS ClientHello - SSL exhaustion pattern"; flow:to_server; content:"|16 03|"; depth:2; threshold: type threshold, track by_src, count 20, seconds 5; sid:9003002; rev:2; classtype:attempted-dos; metadata:affected_product Web_Server, attack_target TLS_Handshake;)

# Rule 13: TLS connection bị RST ngay sau handshake — attacker handshake xong rồi
# drop connection ngay, không gửi HTTP request, nhằm tối đa chi phí CPU server.
# Lưu ý: RST từ client về server cũng xảy ra khi browser cancel request bình thường.
# Trong lab nên theo dõi false positive và tăng threshold nếu cần.
alert tcp any any -> $HOME_NET 443 (msg:"HTTPS FLOOD TLS connection reset immediately after handshake"; flags:R; flow:to_server; threshold: type threshold, track by_src, count 15, seconds 10; sid:9003003; rev:2; classtype:attempted-dos; metadata:affected_product Web_Server, attack_target TLS;)


# ============================================================
# LOGIN FLOOD
# Cơ chế: Flood endpoint đăng nhập (/login, /signin...) với
# tốc độ cao — vừa gây DoS server auth, vừa có thể là
# credential stuffing tấn công tài khoản thực.
# ============================================================

# Rule 14: Nhiều POST tới /login từ một IP — ngưỡng 20 lần/30s.
# Người dùng thực hiếm khi thử login quá 5-6 lần trong 30 giây.
# FIX v2: Thêm http.uri; trước content:"/login" để gắn đúng buffer URI.
alert http any any -> $HOME_NET [80,443] (msg:"LOGIN FLOOD Excessive POST to login endpoint"; flow:established,to_server; http.method; content:"POST"; http.uri; content:"/login"; threshold: type threshold, track by_src, count 20, seconds 30; sid:9004001; rev:2; classtype:attempted-dos; metadata:affected_product Auth_Server, attack_target Login_Endpoint;)

# Rule 15: Bao phủ thêm các endpoint login phổ biến khác (/signin, /auth, /wp-login).
# FIX v2: Thêm http.uri; trước pcre để gắn đúng buffer URI.
alert http any any -> $HOME_NET [80,443] (msg:"LOGIN FLOOD POST to authentication endpoint variants"; flow:established,to_server; http.method; content:"POST"; http.uri; pcre:"/(signin|auth|authenticate|wp-login|admin\/login)/i"; threshold: type threshold, track by_src, count 15, seconds 30; sid:9004002; rev:2; classtype:attempted-dos; metadata:affected_product Auth_Server, attack_target Login_Variants;)

# Rule 16: Login với body rất ngắn — tool tự động thường gửi payload tối thiểu
# (chỉ user=x&pass=y), trong khi form thực có thêm CSRF token, hidden fields...
# FIX v2: Đổi pcre dùng ^ $ sang match đơn giản hơn + thêm dsize:<100
#         vì ^ và $ trên http.request_body không đảm bảo match toàn bộ body
#         (Suricata chỉ inspect chunk đầu của body).
alert http any any -> $HOME_NET [80,443] (msg:"LOGIN FLOOD Minimal login body - automated tool pattern"; flow:established,to_server; http.method; content:"POST"; http.uri; content:"/login"; http.request_body; pcre:"/^[\w]+=.{1,20}&[\w]+=.{1,20}/i"; dsize:<100; threshold: type threshold, track by_src, count 10, seconds 20; sid:9004003; rev:2; classtype:attempted-dos; metadata:affected_product Auth_Server, attack_target Login_Endpoint;)


# ============================================================
# CACHE BUSTING ATTACK
# Cơ chế: Thêm query string ngẫu nhiên (?id=random123) vào
# mỗi request để vô hiệu hoá CDN/reverse proxy cache, buộc
# mọi request đánh thẳng vào origin server.
# ============================================================

# Rule 17: Query string random số dài — pattern điển hình của cache busting tool.
# Regex bắt chuỗi số >= 6 chữ số trong query string, lặp nhiều lần từ một IP.
# FIX v2: Thêm http.uri; trước pcre để gắn đúng buffer URI.
alert http any any -> $HOME_NET [80,443] (msg:"CACHE BUSTING Randomized numeric query string detected"; flow:established,to_server; http.uri; pcre:"/\?[a-z_]+=\d{6,}/i"; threshold: type threshold, track by_src, count 30, seconds 10; sid:9005001; rev:2; classtype:attempted-dos; metadata:affected_product CDN_Cache, attack_target Cache_Layer;)

# Rule 18: Nhiều request tới cùng path nhưng query string khác nhau mỗi lần.
# Dấu hiệu: URL path giống nhau, chỉ phần ? thay đổi liên tục.
# pcre bắt pattern ?cachebust= hoặc ?_= (các tên phổ biến trong tool).
# FIX v2: Thêm http.uri; trước pcre để gắn đúng buffer URI.
alert http any any -> $HOME_NET [80,443] (msg:"CACHE BUSTING Known cache-bypass query parameter pattern"; flow:established,to_server; http.uri; pcre:"/\?(cachebust|_|nocache|rand|r|t|ts|v|ver|bust)=[\w\d]+/i"; threshold: type threshold, track by_src, count 20, seconds 10; sid:9005002; rev:2; classtype:attempted-dos; metadata:affected_product CDN_Cache, attack_target Cache_Layer;)

# Rule 19: Volume GET cao kết hợp có query string — cách đơn giản nhất để bắt
# cache busting khi tool dùng query string tên tùy ý.
# FIX v2: Thêm http.uri; trước content:"?" để gắn đúng buffer URI.
alert http any any -> $HOME_NET [80,443] (msg:"CACHE BUSTING High volume GET with query strings"; flow:established,to_server; http.method; content:"GET"; http.uri; content:"?"; threshold: type threshold, track by_src, count 100, seconds 10; sid:9005003; rev:2; classtype:attempted-dos; metadata:affected_product CDN_Cache, attack_target Cache_Layer;)


# ============================================================
# DNS QUERY FLOOD
# Cơ chế: Gửi lượng lớn DNS lookup — thường dùng subdomain
# ngẫu nhiên để bypass DNS cache, buộc recursive resolution.
# Yêu cầu: $DNS_SERVERS phải được định nghĩa trong suricata.yaml
#           dưới vars: > address-groups: > DNS_SERVERS: "x.x.x.x"
# ============================================================

# Rule 20: Volume DNS query cao từ một IP — 100 query/10s là rất bất thường.
# Server/resolver thực sự hiếm khi phát sinh hơn 20-30 query/10s.
alert udp any any -> $DNS_SERVERS 53 (msg:"DNS FLOOD High volume DNS queries from single source"; threshold: type threshold, track by_src, count 100, seconds 10; sid:9006001; rev:2; classtype:attempted-dos; metadata:affected_product DNS_Server, attack_target DNS;)

# Rule 21: DNS query tới port 53 TCP (zone transfer style) với volume cao.
# DNS qua TCP thường dùng cho zone transfer — volume cao là đáng ngờ.
alert tcp any any -> $DNS_SERVERS 53 (msg:"DNS FLOOD High volume TCP DNS queries"; flags:S; threshold: type threshold, track by_src, count 30, seconds 10; sid:9006002; rev:2; classtype:attempted-dos; metadata:affected_product DNS_Server, attack_target DNS_TCP;)

# Rule 22: DNS ANY query — loại query trả về tất cả record, response rất lớn.
# Thường bị lạm dụng cho DNS amplification attack.
# FIX v2: Bỏ offset:28/depth:2 vì Suricata match trên DNS application layer payload
#         (bắt đầu từ byte 0), không phải raw packet. Offset 28 cũ sẽ miss hoàn toàn.
#         Dùng "|00 FF 00 01|" để match QTYPE=ANY + QCLASS=IN chính xác hơn.
alert udp any any -> $DNS_SERVERS 53 (msg:"DNS FLOOD ANY query type - possible amplification attempt"; content:"|00 FF 00 01|"; threshold: type threshold, track by_src, count 10, seconds 5; sid:9006003; rev:2; classtype:attempted-dos; metadata:affected_product DNS_Server, attack_target DNS_Amplification;)

# ============================================================
# END OF RULES
# SID range: 9000001 - 9006003
# Phiên bản: 2.0 — đã sửa buffer context, negation syntax, DNS offset
# ============================================================
